{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../src/shared/*"],
      "@hub/*": ["../src/hub/*"],
      "@api/*": ["../src/api/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*", "../src/**/*"]
}
