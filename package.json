{
  "name": "taskino",
  "version": "0.1.0",
  "description": "Taskino — Tamagotchi desktop pet with 12 dino characters",
  "main": "./out/main/index.js",
  "author": "kittanet0301",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "electron-vite build",
    "build:web": "vite build --config web/vite.config.ts",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config web/vite.config.ts",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:assets": "node scripts/check-assets.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "i18next": "^26.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.taskino.app",
    "productName": "Taskino",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/uiohook-napi/**"
    ],
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/uiohook-napi/**/*"
    ],
    "extraResources": [
      {
        "from": ".env.production",
        "to": ".env"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
